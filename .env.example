OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Postgres connection used by lib/db.ts. Real value lives in
# /etc/hermes/control_room_postgres.env — see docs/database.md.
CONTROL_ROOM_DATABASE_URL=

# Router A/B Mode (optional).
# When unset, the router uses safe defaults from lib/router/schema.ts
# (expensive models disabled, budget-bounded, cheap-tier recommender).
# When the Settings UI has saved values to the Postgres singleton row
# (see /settings/router), those values win over this env var.
# When set, value is a JSON object. Recognized keys:
#   { "abEnabled": true,
#     "allowExpensiveModels": false,
#     "allowLongPromptWhenExpensive": false,
#     "longPromptThresholdChars": 1500,
#     "maxCostPerRecommendationUsd": 0.03,
#     "maxCostPerAbRunUsd": 0.30,
#     "routerModelId": "gpt-5.4-mini",
#     "fallbackModelId": "gpt-5.4-mini",
#     "fallbackReasoningLevel": "low",
#     "allowedCombos": [
#       { "modelId": "gpt-5.4-mini", "reasoningLevel": "low" },
#       { "modelId": "gpt-5.4-mini", "reasoningLevel": "medium" }
#     ] }
# See lib/router/schema.ts for defaults and lib/router/policy.ts for how
# these are applied. Real credentials never go here.
CONTROL_ROOM_ROUTER_SETTINGS=

# Fake-LLM stub mode. When set to "1", all OpenAI calls (router, Side A,
# Side B) are replaced with deterministic local stubs that exercise the full
# pipeline (router → Side A → Side B → persistence → panel → feedback) without
# spending tokens. Used by `npm run test:e2e` and by local iteration when
# there is no real OpenAI key. Production should leave this unset.
CONTROL_ROOM_FAKE_LLM=

# OpenAI model discovery stub. When set to "1", GET https://api.openai.com/v1/models
# is replaced with a fixed list of four fake ids (gpt-5.4-mini, gpt-5.5,
# gpt-fake-known-extra, gpt-fake-unknown-xyz). Implied by CONTROL_ROOM_FAKE_LLM=1
# — set this on its own when you want real LLM calls but stubbed discovery.
# Production must not enable this.
CONTROL_ROOM_FAKE_OPENAI_MODELS=